{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "type": "timeseries",
      "title": "Gateway events per second",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "sum by (event) (rate(rustlens_bot_gateway_event_total[1m]))",
          "legendFormat": "{{event}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Command duration p95",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, command) (rate(rustlens_bot_command_duration_seconds_bucket[5m])))",
          "legendFormat": "{{command}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Command failures by reason",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "sum by (command, reason) (rate(rustlens_bot_command_failure_total[5m]))",
          "legendFormat": "{{command}} ({{reason}})",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Shard state (sum)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "rustlens_bot_shard_state",
          "legendFormat": "shard {{shard_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "min": -1, "max": 2 }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Interaction failures by type",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "sum by (interaction_type) (rate(rustlens_bot_interaction_failure_total[5m]))",
          "legendFormat": "type {{interaction_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "type": "logs",
      "title": "Bot logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service_name=\"rustlens-bot\"} | json",
          "refId": "A"
        }
      ],
      "options": { "showTime": true, "wrapLogMessage": false, "enableLogDetails": true }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["rustlens", "bot"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "RustLens — Bot",
  "version": 1
}
